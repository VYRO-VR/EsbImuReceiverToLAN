<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:EsbReceiverToLanAndroid.Views"
             x:Class="EsbReceiverToLanAndroid.MainPage"
             Title="VYRO VR Connect"
             BackgroundColor="{StaticResource Gray950}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">
            <!-- Header -->
            <Label x:Name="titleLabel" Text="VYRO VR Connect" FontSize="28" FontAttributes="Bold"
                   TextColor="{StaticResource Gray100}" HorizontalOptions="Center" />
            <Label x:Name="subtitleLabel" Text="Streams SlimeVR tracker data to your PC over Wi-Fi" FontSize="14"
                   TextColor="{StaticResource Gray400}" HorizontalOptions="Center" />

            <!-- Connection -->
            <Frame BackgroundColor="{StaticResource Gray900}" BorderColor="{StaticResource Gray600}"
                   Padding="16" CornerRadius="8">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Connection" FontAttributes="Bold" TextColor="{StaticResource Gray200}" />
                    <Label x:Name="helpLabel"
                           Text="Leave the address blank to auto-detect your SlimeVR server. Keep this headset on the same Wi-Fi as your PC."
                           TextColor="{StaticResource Gray400}" FontSize="12" />
                    <Label x:Name="deviceIpLabel" Text="" TextColor="{StaticResource Gray500}" FontSize="12" />
                    <Picker x:Name="recentPicker" Title="Recent servers" IsVisible="False"
                            TextColor="{StaticResource Gray100}" TitleColor="{StaticResource Gray500}"
                            SelectedIndexChanged="RecentPicker_SelectedIndexChanged" />
                    <Entry x:Name="ipEntry" Placeholder="SlimeVR IP (optional — blank = auto)"
                           PlaceholderColor="{StaticResource Gray500}" TextColor="{StaticResource Gray100}"
                           BackgroundColor="{StaticResource Gray950}" />
                    <HorizontalStackLayout Spacing="8">
                        <Button x:Name="startButton" Text="Start" Clicked="StartButton_Clicked"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                HorizontalOptions="FillAndExpand" />
                        <Button x:Name="testButton" Text="Test" Clicked="TestButton_Clicked"
                                BackgroundColor="{StaticResource Gray600}" TextColor="{StaticResource Gray200}"
                                HorizontalOptions="FillAndExpand" />
                        <Button x:Name="refreshButton" Text="Refresh" Clicked="RefreshButton_Clicked"
                                BackgroundColor="{StaticResource Gray600}" TextColor="{StaticResource Gray200}"
                                HorizontalOptions="FillAndExpand" />
                    </HorizontalStackLayout>
                    <Label x:Name="statusLabel" Text="" TextColor="{StaticResource Gray400}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Trackers -->
            <Frame BackgroundColor="{StaticResource Gray900}" BorderColor="{StaticResource Gray600}"
                   Padding="16" CornerRadius="8">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Connected Trackers" FontAttributes="Bold" TextColor="{StaticResource Gray200}" />
                    <Label x:Name="trackerSummaryLabel" Text="No trackers" TextColor="{StaticResource Gray500}" FontSize="12" />
                    <VerticalStackLayout x:Name="trackerListContainer" Spacing="0" />
                </VerticalStackLayout>
            </Frame>

            <!-- Setup / Help -->
            <Frame BackgroundColor="{StaticResource Gray900}" BorderColor="{StaticResource Gray600}"
                   Padding="16" CornerRadius="8">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Setup &amp; help" FontAttributes="Bold" TextColor="{StaticResource Gray200}" />
                    <Label TextColor="{StaticResource Gray400}" FontSize="13"
                           Text="1. Plug the receiver dongle into this device's USB-C port (a powered USB-C hub/adapter helps on a headset)." />
                    <Label TextColor="{StaticResource Gray400}" FontSize="13"
                           Text="2. Tap &quot;Allow&quot; if Android asks for permission to access the USB device." />
                    <Label TextColor="{StaticResource Gray400}" FontSize="13"
                           Text="3. Keep this device on the same Wi-Fi network as your PC." />
                    <Label TextColor="{StaticResource Gray400}" FontSize="13"
                           Text="4. Start SlimeVR Server on your PC. Leave the IP blank to auto-detect, or type it and tap Test." />
                    <Label TextColor="{StaticResource Gray400}" FontSize="13"
                           Text="5. Connected trackers appear above once the dongle sends data." />
                </VerticalStackLayout>
            </Frame>

            <!-- Activity log -->
            <Frame BackgroundColor="{StaticResource Gray900}" BorderColor="{StaticResource Gray600}"
                   Padding="16" CornerRadius="8">
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Activity log" FontAttributes="Bold"
                               TextColor="{StaticResource Gray200}" VerticalOptions="Center" />
                        <Button Grid.Column="1" x:Name="clearLogButton" Text="Clear" Clicked="ClearLogButton_Clicked"
                                Padding="12,4" FontSize="12" HeightRequest="34"
                                BackgroundColor="{StaticResource Gray600}" TextColor="{StaticResource Gray200}" />
                    </Grid>
                    <ScrollView x:Name="logScroll" HeightRequest="220" BackgroundColor="{StaticResource Gray950}"
                                Padding="8">
                        <Label x:Name="logLabel" Text="Waiting for activity…" FontSize="11"
                               TextColor="{StaticResource Gray300}" LineBreakMode="WordWrap" />
                    </ScrollView>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
